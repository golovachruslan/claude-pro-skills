#!/usr/bin/env bash
#
# post-checkout hook - auto-run setup.sh after initial clone
#
# Runs only once: on the first checkout after cloning (when the
# previous HEAD is the zero ref). Skips on regular branch switches.
#

PREV_HEAD="$1"
NEW_HEAD="$2"
BRANCH_FLAG="$3"

REPO_DIR="$(git rev-parse --show-toplevel)"
MARKER="$REPO_DIR/.setup-done"

# Only run on branch checkout (flag=1), not file checkout (flag=0)
[[ "$BRANCH_FLAG" != "1" ]] && exit 0

# Skip if already set up
[[ -f "$MARKER" ]] && exit 0

# Check if claude CLI is available
command -v claude &>/dev/null || exit 0

# Run setup
echo ""
echo "==> First checkout detected. Running plugin setup..."
echo ""

if bash "$REPO_DIR/setup.sh"; then
  touch "$MARKER"
  echo ""
  echo "==> Setup complete. This won't run again."
else
  echo ""
  echo "==> Setup had errors. Delete .setup-done and re-run 'bash setup.sh' to retry."
fi
